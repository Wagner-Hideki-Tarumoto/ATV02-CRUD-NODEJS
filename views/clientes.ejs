<%- include ('partials/header.ejs') %>
<%- include ('partials/navbar.ejs') %>

<div class="container">
    <div class="card">
        <div class="card-header">
            <h1>Cadastrar cliente</h1>
        </div>
        <div class="card-body">
            <form action="/clientes/cadastrar" method="post">
                <label>Nome do Cliente</label>
                <input type="text" name="nome" placeholder="Insira o nome do cliente" class="form-control" required>

                <label>CPF do Cliente</label>
                <input type="text" name="cpf" placeholder="Insira o CPF do cliente" class="form-control" required>

                <label>Endereço do Cliente</label>
                <input type="text" name="endereco" placeholder="Insira o Endereço do cliente" class="form-control" required>

                <button type="submit" class="btn btn-success">Cadastrar</button>
                <button type="reset" class="btn btn-danger">Limpar</button>
            </form> 
        </div> 
    </div> 
</div> 

<div class="container">
    <div class="card">
        <div class="card-header">
            <h1>Clientes</h1>
        </div>
        <div class="card-body">
            <table>
                <thead>
                    <tr>
                        <th style="width: 60px; text-align: center;">Perfil</th> <th>Nome:</th>
                        <th>CPF:</th>
                        <th>Endereço:</th>
                        <th colspan="2" style="text-align: center;">Ações</th>
                    </tr>
                </thead>
                <tbody>
    <% clientes.forEach(cliente => { %>
        <tr>
            <td style="text-align: center; width: 70px;">
                <img src="/imgs/<%= cliente.nome.toLowerCase() %>.png" width="40" height="40" style="border-radius:50%;" onerror="this.src='/imgs/avatar.png'">
            </td>
            
            <td>
                <%= cliente.nome %>
            </td>
            
            <td>
                <%= cliente.cpf %>
            </td>
            
            <td>
                <%= cliente.endereco %>
            </td>
            
            <td>
                <a href="/clientes/editar/<%= cliente.id %>" class="btn btn-warning" style="color: black !important;">
                    Editar
                </a>
            </td>
            
            <td>
                <a href="/clientes/delete/<%= cliente.id %>" 
                   onclick="return confirm('Deseja mesmo excluir o cliente?')" 
                   class="btn btn-danger" 
                   style="color: white !important;">
                    Excluir
                </a>
            </td>
        </tr>
    <% }) %>
</tbody>
            </table>
        </div> 
    </div> 
</div> 

<%- include ('partials/footer.ejs') %>