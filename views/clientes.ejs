<%- include ('partials/header.ejs') %>
<%- include ('partials/navbar.ejs') %>

<!--FORMULARIO DE CADASTRO-->
<div class="container">
    <div class="card">
        <div class="card-header">
        <h1>Cadastrar cliente</h1>
        </div>
    <div class="card-body">
        <form action="/clientes/cadastrar" method="post">
            <label>Nome do cliente</label>
            <input type="text" name="nome" placeholder="Insira o nome do cliente "class="form-control" required>

            <label>cpf do cliente</label>
            <input type="text" name="cpf" placeholder="Insira o CPF do cliente "class="form-control" required>

            <label>Endereco do cliente</label>
            <input type="text" name="endereco" placeholder="Insira o Endereco do cliente "class="form-control" required>

            <button type="submit" class="btn btn-success">Cadastrar</button>
            <button type="reset" class="btn btn-danger">Limpar</button>
    </div>
</div>

        <div class="container">
            <div class="card">
                <div class="card-header">
                    <h1>Clientes</h1>
                </div>
                <div class="card-body">
                    <table>
                        <thead>
                            <tr>
                                <th></th>
                                <th>Nome:</th>
                                <th>CPF:</th>
                                <th>Endereço:</th>
                                <th colspan="2" style=" text-align: center;">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% clientes.forEach(cliente=> { %>
                                <tr>
                                    <td><img src="imgs/avatar.png" width="30px"></td>
                                    <td>
                                        <%= cliente.nome %>
                                    </td>
                                    <td>
                                        <%= cliente.cpf %>
                                    </td>
                                    <td>
                                        <%= cliente.endereco %>
                                    </td>
                                    <!--Editar-->
                                    <td>
                                        <a href="/clientes/editar/<%=cliente.id%>">
                                        <button class="btn btn-warning">
                                         Editar
                                    </button>
                                    </a>
                                     </td>
                                    <!--Excluir-->
                                     <td>
                                    <a href="/clientes/excluir/<%= cliente.id %>">
                                    <button onclick="return confirm('Deseja mesmo excluir o cliente?')" class="btn btn-danger">
                                        Excluir
                                    </button>
                                    </a>
                                </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <%- include ('partials/footer.ejs') %>