<%- include ('partials/header.ejs') %>
<%- include ('partials/navbar.ejs') %>

<div class="container" style="margin-top: 30px; margin-bottom: 30px;">
    <div class="card bg-dark text-white" style="border: 1px solid #1a365d;">
        <div class="card-header" style="background-color: #0b1a30;">
            <h1 style="color: #ffc107; font-size: 24px; margin: 0;">CADASTRAR PEDIDO</h1>
        </div>
        <div class="card-body">
            <form action="/pedidos/cadastrar" method="POST">
                <div class="form-group mb-3">
                    <label class="text-warning">NÚMERO DO PEDIDO</label>
                    <input type="text" name="numero" placeholder="Insira o número do pedido" required class="form-control bg-secondary text-white">
                </div>
                
                <div class="form-group mb-3">
                    <label class="text-warning">VALOR DO PEDIDO</label>
                    <input type="text" name="valor" placeholder="Insira o valor do pedido" required class="form-control bg-secondary text-white">
                </div>

                <div class="form-group mb-3">
                    <label class="text-warning">CLIENTE</label>
                    <select name="clienteId" class="form-control bg-secondary text-white" required>
                        <option value="">SELECIONE UM CLIENTE...</option>
                        <% clientes.forEach(cliente => { %>
                            <option value="<%= cliente.id %>">
                                <%= cliente.nome %>
                            </option>
                        <% }) %>
                    </select> 
                </div>

                <div class="form-group mb-3">
                    <label class="text-warning">PRODUTOS (MANTENHA CTRL PRESSIONADO PARA SELECIONAR MAIS DE UM)</label>
                    <select name="produtos" multiple required class="form-control bg-secondary text-white" style="height: auto !important; padding: 10px !important;">
                        <% produtos.forEach(produto => { %>
                            <option value="<%= produto.id %>">
                                <%= produto.nome %> - R$ <%= produto.preco %>
                            </option>
                        <% }) %>
                    </select>
                </div>
                
                <button type="submit" class="btn btn-success w-100 font-weight-bold">CADASTRAR PEDIDO</button>
            </form>
        </div>  
    </div>
</div>

<div class="container">
    <div class="card bg-dark text-white" style="border: 1px solid #1a365d;">
        <div class="card-header" style="background-color: #0b1a30;">
            <h1 style="color: #ffc107; font-size: 24px; margin: 0;">PEDIDOS CADASTRADOS</h1>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-dark table-hover" style="vertical-align: middle;">
                    <thead>
                        <tr class="text-warning">
                            <th></th>
                            <th>NÚMERO</th>
                            <th>VALOR</th>
                            <th>NOME DO CLIENTE</th>
                            <th>PRODUTOS</th>
                            <th>AÇÕES</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% pedidos.forEach(pedido => { %>
                            <tr>
                                <td><img src="/imgs/order.png" width="40px" style="border-radius: 50%; border: 2px solid #ffc107;"></td>
                                <td><%= pedido.numero %></td>
                                <td>
                                    <% if (pedido.valor) { %>
                                        <%= Number(pedido.valor).toLocaleString('pt-br', {style: 'currency', currency: 'BRL'}) %>
                                    <% } else { %>
                                        R$ 0,00
                                    <% } %>
                                </td>
                                <td><%= pedido.cliente ? pedido.cliente.nome : 'Cliente não associado' %></td>

                                <td>
                                    <% if(pedido.produtos && pedido.produtos.length > 0) { %>
                                        <% pedido.produtos.forEach((produto, index) => { %>
                                            <span class="badge bg-primary text-white p-2 m-1"><%= produto.nome %></span>
                                        <% }) %>
                                    <% } else { %>
                                        <span class="text-muted">NENHUM PRODUTO</span>
                                    <% } %>
                                </td>

                                <td>
                                    <a onclick="return confirm('Deseja mesmo excluir o pedido?')" href="/pedidos/excluir/<%= pedido.id %>" class="btn btn-danger btn-sm">
                                        EXCLUIR
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<%- include ('partials/footer.ejs') %>